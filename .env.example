# Site URL (used for SEO canonical URLs and OG tags)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Google Apps Script web app URL for template contact forms
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/PASTE_YOUR_DEPLOYMENT_ID/exec

# Optional: Email integration (add your email service credentials here)
# Example using Resend:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_EMAIL=hello@yourdomain.com

# Example using SendGrid:
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
