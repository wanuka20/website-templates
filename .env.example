# Site URL (used for SEO canonical URLs and OG tags)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Fallback Google Apps Script web app URL for template contact forms
NEXT_PUBLIC_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwFCErTZkR4zA0EEprvY3QbNFKfLB6pZ-3xckaYyIyvHY9JLtsXMbBCXeKViOLLkHC8/exec

# Per-template Google Apps Script web app URLs.
# Use these when each template has its own Apps Script deployment.
# The NEXT_PUBLIC_* values are used by contact forms in the browser.
# The non-public values are used by server-rendered sheet content.
# NEXT_PUBLIC_GYM_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_GYM_DEPLOYMENT_ID/exec
# GYM_GOOGLE_SHEET_WEB_APP_URL=https://script.google.com/macros/s/YOUR_GYM_DEPLOYMENT_ID/exec
# NEXT_PUBLIC_RESTAURANT_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_RESTAURANT_DEPLOYMENT_ID/exec
# RESTAURANT_GOOGLE_SHEET_WEB_APP_URL=https://script.google.com/macros/s/YOUR_RESTAURANT_DEPLOYMENT_ID/exec
# NEXT_PUBLIC_SALON_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SALON_DEPLOYMENT_ID/exec
# SALON_GOOGLE_SHEET_WEB_APP_URL=https://script.google.com/macros/s/YOUR_SALON_DEPLOYMENT_ID/exec
# NEXT_PUBLIC_REALESTATE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_REALESTATE_DEPLOYMENT_ID/exec
# REALESTATE_GOOGLE_SHEET_WEB_APP_URL=https://script.google.com/macros/s/YOUR_REALESTATE_DEPLOYMENT_ID/exec
# NEXT_PUBLIC_TUITION_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_TUITION_DEPLOYMENT_ID/exec
# TUITION_GOOGLE_SHEET_WEB_APP_URL=https://script.google.com/macros/s/YOUR_TUITION_DEPLOYMENT_ID/exec

# Optional: Email integration (add your email service credentials here)
# Example using Resend:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_EMAIL=hello@yourdomain.com

# Example using SendGrid:
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
